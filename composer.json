{
    "name": "ksfraser/ksf_fa_api",
    "description": "KSF FrontAccounting API - REST/SOAP + CRM Compatibility Layer (SuiteCRM, SugarCRM, vtiger, OrangeHRM, Odoo, Dolibarr, dotproject, OpenProject, LibreProject)",
    "type": "fa-module",
    "license": "GPL-3.0",
    "require": {
        "php": "^8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Ksfraser\\": "src/Ksfraser/"
        }
    },
    "minimum-stability": "stable",
    "_comment": "===================================================================",
    "_install": "Run: composer install",
    "_test": "Run: ./vendor/bin/phpunit --testdox",
    "_endpoints": {
        "rest_compat": "public/compat/v4_1/rest.php",
        "soap_compat": "public/compat/v4_1/soap.php",
        "rest_native": "public/api/v1/employees.php"
    },
    "_supported_systems": {
        "crm": ["SuiteCRM v4_1", "SugarCRM v4_1", "vtiger v1", "Salesforce", "Dynamics 365"],
        "erp_hrm": ["OrangeHRM", "Odoo XML-RPC", "Dolibarr", "dotproject", "OpenProject", "LibreProject"]
    },
    "_ksf_module_dependencies": {
        "ksf_CRM": "Customer, Contact, Lead, Opportunity entities",
        "ksf_HRM": "Employee entity",
        "ksf_SupportTickets": "Ticket entity",
        "ksf_Marketing": "Campaign entity",
        "ksf_ProjectManagement": "Task entity",
        "ksf_Notes": "Note entity",
        "ksf_Calendar": "Event entity",
        "ksf_AsteriskPBX": "Call entity",
        "ksf_EmailManager": "Email entity",
        "ksf_Documents": "Document entity"
    }
}